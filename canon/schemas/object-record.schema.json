{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://block-street.local/canon/schemas/object-record.schema.json",
  "title": "CanonObjectRecord",
  "type": "object",
  "required": [
    "canon_id",
    "canonical_name",
    "object_type",
    "domain",
    "description",
    "status",
    "version",
    "owner",
    "steward",
    "authority",
    "created_at",
    "updated_at",
    "implementation_status",
    "validation_status",
    "security_classification",
    "privacy_classification"
  ],
  "properties": {
    "canon_id": {
      "type": "string",
      "pattern": "^COS-[A-Z]+-\\d{6}$"
    },
    "canonical_name": { "type": "string", "minLength": 1 },
    "object_type": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "purpose": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "draft",
        "under_review",
        "approved",
        "implementation_ready",
        "in_implementation",
        "implemented",
        "validated",
        "released",
        "maintained",
        "deprecated",
        "retired",
        "historical",
        "rejected",
        "active"
      ]
    },
    "version": { "type": "string" },
    "owner": { "type": "string" },
    "steward": { "type": "string" },
    "authority": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "effective_at": { "type": "string" },
    "deprecated_at": { "type": "string" },
    "retired_at": { "type": "string" },
    "source_document": { "type": "string" },
    "repository_location": { "type": "string" },
    "implementation_status": { "type": "string" },
    "validation_status": { "type": "string" },
    "security_classification": { "type": "string" },
    "privacy_classification": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "legacy_requirement_id": { "type": "string" },
    "localbrain_support": { "type": "string" },
    "ai_retrieval_eligible": { "type": "boolean" }
  },
  "additionalProperties": true
}
