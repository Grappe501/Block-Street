{
  "templates": [
    {
      "id": "tpl-security-alert",
      "key": "auth.suspicious_login",
      "name": "Suspicious Login Alert",
      "category": "security",
      "channel": "in_app",
      "language": "en",
      "title_template": "Suspicious sign-in detected",
      "body_template": "A sign-in attempt was made on your account. Review your account security.",
      "summary_template": "Review account security",
      "action_label_template": "Review security",
      "default_priority": "critical",
      "required_variables": [],
      "allowed_variables": ["action_url"],
      "approval_status": "approved",
      "version": 1,
      "status": "active"
    },
    {
      "id": "tpl-mission-comment",
      "key": "mission.comment",
      "name": "Mission Comment",
      "category": "mission",
      "channel": "in_app",
      "language": "en",
      "title_template": "New comment on {{mission.title}}",
      "body_template": "{{actor.name}} commented on your mission.",
      "summary_template": "New mission comment",
      "action_label_template": "View mission",
      "default_priority": "normal",
      "required_variables": ["mission.title"],
      "allowed_variables": ["mission.title", "actor.name", "action_url"],
      "approval_status": "approved",
      "version": 1,
      "status": "active"
    },
    {
      "id": "tpl-mission-deadline",
      "key": "mission.deadline_approaching",
      "name": "Mission Deadline Approaching",
      "category": "mission",
      "channel": "in_app",
      "language": "en",
      "title_template": "Mission deadline approaching",
      "body_template": "{{mission.title}} is due {{mission.due_at}}.",
      "summary_template": "Deadline tomorrow",
      "action_label_template": "Open mission",
      "default_priority": "important",
      "required_variables": ["mission.title", "mission.due_at"],
      "allowed_variables": ["mission.title", "mission.due_at", "action_url"],
      "approval_status": "approved",
      "version": 1,
      "status": "active"
    },
    {
      "id": "tpl-campaign-announcement",
      "key": "campaign.organization_announcement",
      "name": "Organization Announcement",
      "category": "organization",
      "channel": "email",
      "language": "en",
      "subject_template": "{{organization.name}} — {{campaign.title}}",
      "title_template": "{{campaign.title}}",
      "body_template": "{{campaign.body}}",
      "summary_template": "Organization announcement",
      "action_label_template": "Read more",
      "default_priority": "normal",
      "required_variables": ["organization.name", "campaign.title", "campaign.body"],
      "allowed_variables": ["organization.name", "campaign.title", "campaign.body", "action_url"],
      "approval_status": "approved",
      "version": 1,
      "status": "active"
    }
  ]
