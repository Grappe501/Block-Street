        "geographic_question": "How is registration progressing in this county?"
      },
      {
        "position": "Institution lead (college campus)",
        "functional_to": "college_leader",
        "geographic_to": "county_volunteer_lead",
        "functional_question": "Are campus education goals on track?",
        "geographic_question": "How are campus needs resourced in this county?"
      }
    ]
  },
  "nodes": [
