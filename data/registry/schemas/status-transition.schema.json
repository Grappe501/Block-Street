{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://block-street.netlify.app/schemas/status-transition.json",
  "title": "Status Timeline Transition Record",
  "description": "PHASE-002.5 STS-M16 — append-only status history",
  "type": "object",
  "required": [
    "id", "entityId", "entityType", "category", "toStatus", "changedAt", "changedBy"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^STS-[a-zA-Z0-9-]+$" },
    "entityId": { "type": "string" },
    "entityType": {
      "type": "string",
      "enum": ["County", "Institution", "Participant", "Committee", "Event", "Project", "Relationship"]
    },
    "category": {
      "type": "string",
      "enum": ["operational", "verification", "organizing", "visibility", "system"]
    },
    "fromStatus": { "type": ["string", "null"] },
    "toStatus": { "type": "string" },
    "changedAt": { "type": "string", "format": "date-time" },
    "changedBy": { "type": "string", "description": "system | admin | user id" },
    "reason": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
