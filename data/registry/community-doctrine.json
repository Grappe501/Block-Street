{
  "version": "1.0.0",
  "docPath": "docs/phase-04/COMMUNITY_DOCTRINE.md",
  "motto": "The platform provides the structure. The people create the culture.",
  "principle": "One philosophy for every community — campus, county, committee, project, and beyond.",
  "purpose": "Define what a community is and establish shared philosophy for the Community Operating System.",
  "whatIsACommunity": {
    "is": [
      "placeWherePeopleWorkTogether",
      "participantOwnedCulture",
      "graphConnectedRegistryNode",
      "lifecycleAware",
      "equalInPlatformRights"
    ],
    "isNot": ["staticHubPage", "orgImposedOnParticipants", "softwareTierHierarchy"]
  },
  "communityTypes": [
    { "key": "campus", "examples": ["UCA", "University of Arkansas"], "source": "INST-003" },
    { "key": "county", "examples": ["Pulaski", "Faulkner"], "source": "CNTY-002" },
    { "key": "committee", "examples": ["Campus Outreach", "Communications"], "source": "COM-001" },
    { "key": "project", "examples": ["Food Drive", "Campus Cleanup"], "source": "Step 4.5" },
    { "key": "interestGroup", "examples": ["Environmental organizers"], "source": "future" },
    { "key": "regionalCollaboration", "examples": ["Central Arkansas coalition"], "source": "Step 4.11" },
    { "key": "highSchoolFuture", "source": "ADT-M15 Phase 9" },
    { "key": "alumniNetworkFuture", "source": "Phase 9 JRN" }
  ],
  "sharedPhilosophy": ["welcoming", "participatory", "transparent", "connected", "memorable", "healthyMetrics"],
  "communityOperatingSystem": {
    "description": "Each community runs standard subsystems — network of OS instances statewide",
    "modules": [
      "constitution",
      "headquarters",
      "peopleAndRoles",
      "calendar",
      "committees",
      "projects",
      "communications",
      "knowledge",
      "resources",
      "marketplace",
      "analytics",
      "memory",
      "collaboration"
    ],
    "personalHQWindow": true,
    "compositionNotDuplication": true
  },
  "communityConstitution": {
    "description": "Every community defines identity within shared framework — authentic local culture",
    "signatureFeature": true,
    "elements": [
      { "key": "purpose", "label": "Purpose", "description": "Why this community exists" },
      { "key": "goals", "label": "Goals", "description": "What to accomplish this semester or year" },
      { "key": "values", "label": "Values", "description": "How members agree to work together" },
      { "key": "currentPriorities", "label": "Current Priorities", "description": "Most important initiatives now" },
      { "key": "successStories", "label": "Success Stories", "description": "What the community has achieved" },
      { "key": "openOpportunities", "label": "Open Opportunities", "description": "Where help is needed" },
      { "key": "communityTraditions", "label": "Community Traditions", "description": "Unique events, rituals, recurring activities" }
    ],
    "participantEditable": true,
    "extendsCommunityDNA": "CID-M13",
    "v1": "purposeWelcomePrioritiesStub"
  },
  "communityHQParallel": {
    "ref": "PHQ-001",
    "sections": [
      { "personal": "My Mission", "community": "Community Purpose" },
      { "personal": "My Communities", "community": "Parent/sibling communities" },
      { "personal": "My Network", "community": "Members and roles" },
      { "personal": "My Journey", "community": "Community lifecycle" },
      { "personal": "My Calendar", "community": "Community calendar" },
      { "personal": "My Opportunities", "community": "Open opportunities and marketplace" },
      { "personal": "My Impact", "community": "Community analytics" },
      { "personal": "My Passport", "community": "Community memory" }
    ]
  },
  "structureAndCulture": {
    "platformProvides": ["osSubsystems", "graphConnections", "attentionRespectingComms", "healthAnalyticsFramework", "crossCommunityRails"],
    "peopleCreate": ["constitutionContent", "relationships", "discussionCulture", "localSuccessMeaning", "coalitions"]
  },
  "integrations": {
    "phase2": { "extends": "CID-001", "adds": ["constitution", "communityHQ", "fullOS"] },
    "phase3": {
      "phqCommunities": "entryToCommunityHQ",
      "obeVs412": "OBE participant discovery; 4.12 community publish needs"
    }
  },
  "communityEquality": {
    "ref": "OM-006",
    "noPermanentHierarchy": true,
    "sameOSCapabilitySet": true
  },
  "v1Scope": {
    "doctrineAndConstitutionSpec": true,
    "constitutionStubOnHubs": true,
    "fullOS": "Steps 4.2-4.14"
  },
  "implementation": {
    "gate": "constitution schema required for new community types",
    "files": [
      "src/lib/community/CommunityOS.ts",
      "src/lib/community/CommunityConstitution.ts",
      "src/lib/community/assembleCommunityHQ.ts"
    ]
  }
}
