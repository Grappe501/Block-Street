    { "id": "registration_lead", "countyLabel": "Registration Lead", "institutionLabel": "Registration Lead", "priority": 4 },
    { "id": "canvass_lead", "countyLabel": "Canvass Lead", "institutionLabel": "Canvass Lead", "priority": 5 },
    { "id": "phone_bank_lead", "countyLabel": "Phone Bank Lead", "institutionLabel": "Phone Bank Lead", "priority": 6 },
    { "id": "postcard_lead", "countyLabel": "Postcard Lead", "institutionLabel": "Postcard Lead", "priority": 7 }
  ],
  "goalKinds": [
    { "id": "registration", "label": "Registration Goal", "kpiId": "kpi-registration-goal", "nonpartisan": true },
    { "id": "vote_participation", "label": "Vote Participation Goal", "nonpartisan": true }
  ],
  "functionalLanes": [
