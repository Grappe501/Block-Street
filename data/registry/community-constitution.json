    "participantEditable": true,
    "appendOnlyHistory": true,
    "v1": "missionWelcomePrioritiesStub"
  },
  "communityOperatingSystem": {
    "ref": "PHASE_4_MASTER_SEQUENCE",
    "modules": ["constitution", "charter", "headquarters", "calendar", "committees", "projects", "communications", "knowledge", "resources", "marketplace", "analytics", "memory", "collaboration"]
  },
  "v1Scope": {
    "constitutionAndHierarchy": true,
    "chartersSpec": true,
    "charterStubOnHubs": true,
    "fullOS": "Steps 4.2-4.14 complete — COS-001 certification"
  },
  "implementation": {
    "gate": "Constitution inheritance + Charter schema required for all community types",
    "requiredReading": true,
    "files": [
      "src/lib/community/CommunityConstitution.ts",
      "src/lib/community/CommunityCharter.ts",
      "src/lib/community/assembleCommunityHQ.ts"
    ]
  }
