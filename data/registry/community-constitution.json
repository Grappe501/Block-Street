  "movementInfrastructure": true,
  "constitutionalHierarchy": [
    { "layer": "platformConstitution", "ref": "Phase 1 BUILD-BIBLE", "scope": "Entire ASYON" },
    { "layer": "communityConstitution", "ref": "This document CCN-001", "scope": "Inherited by all communities" },
    { "layer": "communityIdentity", "ref": "CID-001 + Community Charter", "scope": "Per-community identity" },
    { "layer": "communityActivity", "ref": "Steps 4.4–4.7", "scope": "Projects, events, committees" },
    { "layer": "communityLegacy", "ref": "CLS-001", "scope": "Legacy and institutional history" }
  ],
  "definitionOfCommunity": "Group connected by shared place, purpose, interest, or commitment",
  "communityTypes": [
    "county",
    "university",
    "communityCollege",
    "tradeSchool",
    "highSchoolFuture",
    "committee",
    "volunteerTeam",
    "project",
    "alumniNetwork",
    "regionalCollaboration",
    "statewideInitiative"
  ],
  "equalStanding": {
    "noInherentHierarchy": true,
    "sameArchitecturalSupport": true,
    "differsByParticipationNotImportance": true,
    "ref": "OM-006"
  },
  "communityPurpose": [
    "buildRelationships",
    "developLeaders",
    "supportMeaningfulParticipation",
    "strengthenLocalConnections",
    "createServiceOpportunities",
    "preserveInstitutionalKnowledge",
    "welcomeNewParticipants",
    "helpMembersGrow"
  ],
  "communityRights": [
    "developOwnIdentity",
    "tellOwnStory",
    "celebrateAchievements",
    "defineLocalPriorities",
    "organizeAroundLocalNeeds",
    "createCommittees",
    "launchProjects",
    "buildPartnerships",
    "archiveOwnHistory"
  ],
  "communityResponsibilities": [
    "welcomingNewcomers",
    "respectingParticipants",
    "maintainingAccurateInformation",
    "supportingCollaboration",
    "developingFutureLeaders",
    "sharingKnowledge",
    "preservingCommunityHistory",
    "encouragingRespectfulParticipation"
  ],
  "communityIdentity": {
    "elements": ["mission", "vision", "goals", "traditions", "history", "culture", "currentPriorities", "communityStories", "localResources"],
    "growsNaturally": true,
    "extendsCommunityDNA": "CID-M13"
  },
  "communityLeadership": {
    "servesCommunity": true,
    "responsibilities": ["facilitatingParticipation", "developingOthers", "coordinatingProjects", "welcomingNewMembers", "protectingCulture", "sharingKnowledge"],
    "rotatesAndExpands": true
  },
  "communityMembership": {
    "basedOnParticipationNotStatus": true,
    "multipleSimultaneous": true,
    "complementNotCompete": true
  },
  "communityRelationships": {
    "examples": ["campusCounty", "countyCounty", "campusCampus", "committeeProject", "projectVolunteerTeam", "regionalStatewide"],
    "noIsolation": true
  },
  "communityMemory": {
    "preserves": ["projects", "milestones", "events", "volunteerStories", "leadershipTransitions", "photos", "resources", "meetingNotes"],
    "implementsAt": "CLS-001"
  },
  "communityGrowth": {
    "healthySignals": ["welcomingCulture", "volunteerParticipation", "leadershipDevelopment", "knowledgeSharing", "relationshipBuilding", "successfulProjects", "communityResilience"],
    "measuredByStrengthNotSize": true
  },
  "communityAutonomy": {
    "localDecisionsWithinFramework": true,
    "toolsNotDirectives": true
  },
  "communityContinuity": {
    "survivesLeadershipTransitions": true,
    "knowledgeAvailableToFutureOrganizers": true
  },
  "communityCharters": {
    "description": "Per-community document built on inherited Constitution — genuine local voice",
    "signatureFeature": true,
    "orchestrator": "getCommunityCharter(communityId)",
    "constitutionVsCharter": {
      "constitution": "Inherited by every community — consistent statewide",
      "charter": "Written by that specific community — living document"
    },
    "elements": [
      "missionThisYear",
      "goalsThisSemester",
      "meetingRhythm",
      "traditions",
      "values",
      "currentProjects",
      "howNewMembersGetInvolved",
      "annualPriorities",
      "successStories",
      "communityAgreements"
