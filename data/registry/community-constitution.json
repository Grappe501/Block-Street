{
  "version": "1.1.0",
  "docPath": "docs/phase-04/COMMUNITY_CONSTITUTION.md",
  "requiredReadingForBurt": true,
  "motto": "Communities are built by people, strengthened by relationships, and sustained by shared purpose.",
  "principle": "The software exists to support communities — not define them.",
