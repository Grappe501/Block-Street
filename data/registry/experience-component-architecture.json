  "guidingPrinciple": "Build components once. Compose experiences forever.",
  "componentPhilosophy": {
    "pagesNeverDesignedIndividually": true,
    "componentNotPageIsPrimaryUnit": true,
    "operationalComponentsNotGenericWidgets": true,
    "componentsBecomeSmarterOverTime": true,
    "meaningfulConceptsNotGenericWidgets": true
  },
  "traditionalUILibraryContains": [
    "Buttons",
    "Forms",
    "Tables",
    "Cards"
  ],
  "compositionModel": {
    "layers": [
      "Experience",
      "Workspace",
      "Panels",
      "OperationalComponents",
      "PrimitiveComponents",
      "DesignTokens"
    ],
    "layerCount": 6
  },
  "componentHierarchyLevelCount": 6,
  "componentHierarchy": [
    {
      "level": 1,
      "id": "designTokens",
      "name": "Design Tokens",
      "responsibility": "Foundation only",
      "includes": ["Typography", "Spacing", "Color", "Motion", "Elevation", "Accessibility", "Icons"],
      "businessKnowledge": false
    },
    {
      "level": 2,
      "id": "primitiveComponents",
      "name": "Primitive Components",
      "responsibility": "Small reusable elements",
      "examples": ["Button", "Input", "Checkbox", "Badge", "Avatar", "Icon", "Chip", "Tooltip", "ProgressBar"],
      "businessKnowledge": false
    },
    {
      "level": 3,
      "id": "compositeComponents",
      "name": "Composite Components",
      "responsibility": "Combinations of primitives",
      "examples": ["SearchBox", "DatePicker", "CalendarWidget", "NavigationRail", "Timeline", "CommentThread", "ApprovalPanel", "NotificationCenter"],
      "understandsWorkflow": true
    },
    {
      "level": 4,
      "id": "operationalComponents",
      "name": "Operational Components",
      "responsibility": "Core of the platform — domain-aware",
      "examples": [
        "MissionCard",
        "VolunteerCard",
        "LeadershipCard",
        "KnowledgeCard",
        "CommunityCard",
        "PartnershipCard",
        "InstitutionCard",
        "CountyCard",
        "StoryCard",
        "DigitalTwinCard",
        "CommunityHealthCard",
        "DecisionPanel"
      ]
    },
    {
      "level": 5,
      "id": "workspaceModules",
      "name": "Workspace Modules",
      "responsibility": "Collections of operational components",
      "examples": [
        "MissionDashboard",
        "VolunteerQueue",
        "ExecutiveBriefing",
        "CommunityTimeline",
        "KnowledgeFeed",
        "LeadershipPipeline",
        "CalendarPanel"
      ]
    },
    {
      "level": 6,
      "id": "completeWorkspaces",
      "name": "Complete Workspaces",
      "responsibility": "Entire experiences from reusable modules",
      "examples": [
        "PersonalOperatingSystem",
        "VolunteerSuccessCenter",
        "MissionOperationsCenter",
        "LeadershipAcademy",
        "ExecutiveOperationsCenter",
        "KnowledgeObservatory"
      ]
    }
  ],
  "componentQuestions": [
    "WhatIsThis",
    "WhyDoesItMatter",
    "WhatCanIDo",
    "WhatHappenedRecently",
    "WhatShouldHappenNext"
  ],
