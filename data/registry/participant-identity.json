{
  "version": "1.0.0",
  "docPath": "docs/phase-03/PARTICIPANT_IDENTITY_DOCTRINE.md",
  "motto": "Start with people, not users.",
  "phaseName": "People & Relationship System",
  "phaseQuestion": "Who is this person, how do they grow, and how do they connect to others?",
  "participantDefinition": "A person engaged with ASYON — with relationships, aspirations, interests, skills, communities, and a story.",
  "idPattern": "PRT-{uuid}",
  "identityDimensions": [
    "name",
    "county",
    "campus",
    "ageBracket",
    "interests",
    "skills",
    "passions",
    "personalMission",
    "story"
  ],
  "belongingEdges": [
    { "type": "resides_in", "destination": "County" },
    { "type": "attends", "destination": "Institution" },
    { "type": "member_of", "destination": "Committee", "v1": "future" }
  ],
  "personalMission": {
    "requirementId": "PRM-001",
    "description": "Living statement of purpose — not a resume",
    "maxLengthRecommended": 500,
    "visibilityOptions": ["public", "community", "network", "private"],
    "examples": [
      "I'm helping organize students at UCA.",
      "I'm building youth engagement in Saline County.",
      "I want to connect students interested in environmental conservation.",
      "I'm recruiting first-time volunteers across Southeast Arkansas."
    ],
    "uses": [
      "Introduce participants to one another",
      "Recommend collaborators",
      "Build complementary teams",
      "Help new members find belonging",
      "Show progress as role evolves"
    ]
  },
  "layers": {
    "person": "Identity, mission, journey, graph node",
    "account": "Auth credentials — Phase 7",
    "profile": "Privacy-filtered presentation"
  },
  "v1ProfileMinimum": [
    "name",
    "county",
    "campus",
    "interests",
    "personalMission",
    "privacyLevel"
  ]
}
