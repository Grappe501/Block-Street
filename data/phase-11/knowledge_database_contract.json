{
  "contract_id": "KNW-DB-001",
  "protocol": "11.12-W2",
  "system_id": "ADP-001",
  "principle": "One canonical record per canonical_id; soft archive only; immutable versions and history; no orphan knowledge",
  "tables": [
    {"name": "knowledge_domains", "primary_key": "canonical_id", "foreign_keys": [{"institution_id": "institutions.institution_id"}]},
    {"name": "knowledge_collections", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_artifacts", "primary_key": "canonical_id", "foreign_keys": [{"collection_id": "knowledge_collections.canonical_id"}, {"domain_id": "knowledge_domains.canonical_id"}], "constraints": ["no_orphan_artifact"]},
    {"name": "knowledge_versions", "primary_key": "version_id", "foreign_keys": [{"artifact_id": "knowledge_artifacts.canonical_id"}], "immutable": true},
    {"name": "knowledge_claims", "primary_key": "canonical_id", "foreign_keys": [{"artifact_id": "knowledge_artifacts.canonical_id"}], "constraints": ["validated_requires_evidence"]},
    {"name": "knowledge_sources", "primary_key": "canonical_id"},
    {"name": "knowledge_citations", "primary_key": "canonical_id", "foreign_keys": [{"claim_id": "knowledge_claims.canonical_id"}, {"source_id": "knowledge_sources.canonical_id"}], "constraints": ["no_orphan_citation"]},
    {"name": "knowledge_evidence_references", "primary_key": "canonical_id", "foreign_keys": [{"claim_id": "knowledge_claims.canonical_id"}], "polymorphic_link": true},
    {"name": "knowledge_relationships", "primary_key": "relationship_id"},
    {"name": "knowledge_reviews", "primary_key": "canonical_id", "foreign_keys": [{"artifact_id": "knowledge_artifacts.canonical_id"}]},
    {"name": "knowledge_approvals", "primary_key": "canonical_id", "foreign_keys": [{"artifact_id": "knowledge_artifacts.canonical_id"}]},
    {"name": "knowledge_courses", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_modules", "primary_key": "canonical_id", "foreign_keys": [{"course_id": "knowledge_courses.canonical_id"}]},
    {"name": "knowledge_lessons", "primary_key": "canonical_id", "foreign_keys": [{"module_id": "knowledge_modules.canonical_id"}, {"course_id": "knowledge_courses.canonical_id"}]},
    {"name": "knowledge_learning_objects", "primary_key": "canonical_id", "foreign_keys": [{"lesson_id": "knowledge_lessons.canonical_id"}]},
    {"name": "knowledge_learning_paths", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_learning_enrollments", "primary_key": "canonical_id", "foreign_keys": [{"course_id": "knowledge_courses.canonical_id"}]},
    {"name": "knowledge_learning_completions", "primary_key": "canonical_id", "foreign_keys": [{"course_id": "knowledge_courses.canonical_id"}], "constraints": ["binds_course_version"]},
    {"name": "knowledge_learning_progress", "primary_key": "canonical_id", "foreign_keys": [{"enrollment_id": "knowledge_learning_enrollments.canonical_id"}]},
    {"name": "knowledge_skills", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_competencies", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_competency_levels", "primary_key": "canonical_id", "foreign_keys": [{"competency_id": "knowledge_competencies.canonical_id"}]},
    {"name": "knowledge_human_competency_records", "primary_key": "canonical_id", "foreign_keys": [{"competency_id": "knowledge_competencies.canonical_id"}]},
    {"name": "knowledge_assessments", "primary_key": "canonical_id"},
    {"name": "knowledge_assessment_attempts", "primary_key": "canonical_id", "foreign_keys": [{"assessment_id": "knowledge_assessments.canonical_id"}]},
    {"name": "knowledge_assessment_results", "primary_key": "canonical_id", "foreign_keys": [{"attempt_id": "knowledge_assessment_attempts.canonical_id"}]},
    {"name": "knowledge_certifications", "primary_key": "canonical_id"},
    {"name": "knowledge_certification_awards", "primary_key": "canonical_id", "foreign_keys": [{"certification_id": "knowledge_certifications.canonical_id"}], "constraints": ["requirements_met_required"]},
    {"name": "knowledge_certification_requirements", "primary_key": "canonical_id", "foreign_keys": [{"certification_id": "knowledge_certifications.canonical_id"}]},
    {"name": "knowledge_playbooks", "primary_key": "canonical_id", "foreign_keys": [{"artifact_id": "knowledge_artifacts.canonical_id"}]},
    {"name": "knowledge_sops", "primary_key": "canonical_id", "foreign_keys": [{"artifact_id": "knowledge_artifacts.canonical_id"}]},
    {"name": "knowledge_research_projects", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_research_findings", "primary_key": "canonical_id", "foreign_keys": [{"project_id": "knowledge_research_projects.canonical_id"}]},
    {"name": "knowledge_institutional_insights", "primary_key": "canonical_id"},
    {"name": "knowledge_institutional_lessons", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_institutional_memory", "primary_key": "canonical_id", "foreign_keys": [{"institution_id": "institutions.institution_id"}]},
    {"name": "knowledge_translations", "primary_key": "canonical_id", "foreign_keys": [{"source_artifact_id": "knowledge_artifacts.canonical_id"}]},
    {"name": "knowledge_tutor_conversations", "primary_key": "canonical_id"},
    {"name": "knowledge_ai_suggestions", "primary_key": "canonical_id", "constraints": ["ai_labeled", "does_not_create_truth"]},
    {"name": "knowledge_human_review_decisions", "primary_key": "canonical_id"},
    {"name": "knowledge_conflicts", "primary_key": "canonical_id"},
    {"name": "knowledge_gaps", "primary_key": "canonical_id", "foreign_keys": [{"domain_id": "knowledge_domains.canonical_id"}]},
    {"name": "knowledge_corrections", "primary_key": "canonical_id", "foreign_keys": [{"artifact_id": "knowledge_artifacts.canonical_id"}]},
    {"name": "knowledge_stewardship_assignments", "primary_key": "canonical_id"},
    {"name": "knowledge_version_audit", "primary_key": "audit_id", "immutable": true},
    {"name": "knowledge_history_events", "primary_key": "event_id", "immutable": true, "append_only": true}
  ]
}
